# ==============================================================================
# JobRadar - Global Environment Configuration Template
# ==============================================================================
# This is a template for the master configuration file for the entire monorepo.
# Copy this file to '.env' and fill in the values for your local environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment & General Config
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=8000

# ------------------------------------------------------------------------------
# 2. Service URLs
# ------------------------------------------------------------------------------
# API server address
API_URL=http://localhost:8000

# Next.js web application address
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# 3. Database (PostgreSQL / Prisma)
# ------------------------------------------------------------------------------
# Prisma automatically loads variables from the .env file in the root/project.
# Replace values with your local PostgreSQL credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobradar?schema=public"

# ------------------------------------------------------------------------------
# 4. Redis / Queue Configuration (BullMQ)
# ------------------------------------------------------------------------------
# BullMQ requires a Redis instance to manage job queues.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://127.0.0.1:6379"

# ------------------------------------------------------------------------------
# 5. Security & Authentication
# ------------------------------------------------------------------------------
# Secrets for JWT token signing (Fastify JWT)
JWT_SECRET=super_secret_jobradar_jwt_key_change_me_in_production
JWT_EXPIRES_IN=7d

# Better Auth Configuration
BETTER_AUTH_SECRET=super_secret_better_auth_key_change_me_in_production
BETTER_AUTH_URL=http://localhost:8000


# ------------------------------------------------------------------------------
# 6. AI Layer (Gemini & OpenAI)
# ------------------------------------------------------------------------------
# API keys for matching jobs, parsing resumes, and running similarity logic.
# Use either Gemini (Google) or OpenAI as required by the backend system.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Default LLM configuration
LLM_MODEL=gemini-2.5-flash

# ------------------------------------------------------------------------------
# 7. Notification Channels
# ------------------------------------------------------------------------------
# SMTP Configuration for Email Alerts
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="JobRadar <noreply@jobradar.com>"

# Telegram Alerts Config
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Alerts Config
DISCORD_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# 8. Crawler Configuration (Playwright / Cheerio)
# ------------------------------------------------------------------------------
# Set to 'true' to run Playwright in headless mode
BROWSER_HEADLESS=true

# ------------------------------------------------------------------------------
# 9. Cloudflare R2 Storage (Optional)
# ------------------------------------------------------------------------------
# Configure to store resumes in R2; defaults to local file storage if missing.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
